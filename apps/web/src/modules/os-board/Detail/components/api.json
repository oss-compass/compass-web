    "/services/dashboard_alert/update_rule": {
      "post": {
        "description": "更新预警规则",
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "parameters": [
          {
            "in": "formData",
            "name": "id",
            "description": "规则ID",
            "type": "integer",
            "format": "int32",
            "required": true
          },
          {
            "in": "formData",
            "name": "monitorType",
            "description": "监控类型: community(社区), repo(仓库)",
            "type": "string",
            "enum": ["community", "repo"],
            "required": false
          },
          {
            "in": "formData",
            "name": "targetRepo",
            "description": "目标仓库地址",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "metricKey",
            "description": "监控指标key",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "metricName",
            "description": "监控指标名称",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "timeRange",
            "description": "最近几个月",
            "type": "integer",
            "format": "int32",
            "required": false
          },
          {
            "in": "formData",
            "name": "operatorType",
            "description": "比较类型",
            "type": "string",
            "enum": ["value", "percentage"],
            "required": false
          },
          {
            "in": "formData",
            "name": "operator",
            "description": "比较运算符",
            "type": "string",
            "enum": ["\u003e", "\u003e=", "\u003c", "\u003c=", "=", "!="],
            "required": false
          },
          {
            "in": "formData",
            "name": "threshold",
            "description": "预警阈值",
            "type": "number",
            "format": "double",
            "required": false
          },
          {
            "in": "formData",
            "name": "level",
            "description": "预警级别",
            "type": "string",
            "enum": ["critical", "warning", "info"],
            "required": false
          },
          {
            "in": "formData",
            "name": "description",
            "description": "规则描述",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "enabled",
            "description": "是否启用",
            "type": "boolean",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "更新预警规则",
            "schema": {
              "$ref": "#/definitions/Openapi_Entities_DashboardAlertRuleResponse"
            }
          },
          "403": {
            "description": "需要编辑权限"
          },
          "404": {
            "description": "规则不存在"
          },
          "422": {
            "description": "更新失败"
          }
        },
        "tags": ["DashboardAlertService / 预警服务"],
        "operationId": "postServicesDashboardAlertUpdateRule"
      }
    },
    "/services/dashboard_alert/create_rule": {
      "post": {
        "description": "创建预警规则",
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "parameters": [
          {
            "in": "formData",
            "name": "identifier",
            "description": "看板唯一编码",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "monitorType",
            "description": "监控类型: community(社区), repo(仓库)",
            "type": "string",
            "enum": ["community", "repo"],
            "required": true
          },
          {
            "in": "formData",
            "name": "targetRepo",
            "description": "目标仓库地址",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "metricKey",
            "description": "监控指标key",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "timeRange",
            "description": "最近几个月",
            "type": "integer",
            "format": "int32",
            "required": true
          },
          {
            "in": "formData",
            "name": "metricName",
            "description": "监控指标名称",
            "type": "string",
            "required": true
          },
          {
            "in": "formData",
            "name": "operator",
            "description": "比较运算符",
            "type": "string",
            "enum": ["\u003e", "\u003e=", "\u003c", "\u003c=", "=", "!="],
            "required": true
          },
          {
            "in": "formData",
            "name": "operatorType",
            "description": "比较类型: value(数值), percentage(百分比)",
            "type": "string",
            "enum": ["value", "percentage"],
            "required": true
          },
          {
            "in": "formData",
            "name": "threshold",
            "description": "预警阈值",
            "type": "number",
            "format": "double",
            "required": true
          },
          {
            "in": "formData",
            "name": "level",
            "description": "预警级别: critical(严重), warning(警告), info(提示)",
            "type": "string",
            "enum": ["critical", "warning", "info"],
            "required": true
          },
          {
            "in": "formData",
            "name": "description",
            "description": "规则描述",
            "type": "string",
            "required": false
          },
          {
            "in": "formData",
            "name": "enabled",
            "description": "是否启用",
            "type": "boolean",
            "default": true,
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "创建预警规则",
            "schema": {
              "$ref": "#/definitions/Openapi_Entities_DashboardAlertRuleResponse"
            }
          },
          "403": {
            "description": "需要编辑权限"
          },
          "422": {
            "description": "参数错误或保存失败"
          }
        },
        "tags": ["DashboardAlertService / 预警服务"],
        "operationId": "postServicesDashboardAlertCreateRule"
      }
    }
